{
  "name": "ol-keycloakify",
  "version": "0.1.4",
  "description": "Keycloakify theme for Open Learning",
  "repository": {
    "type": "git",
    "url": "git://github.com/mitodl/ol-keycloakify.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "keycloakify sync-extensions",
    "dev": "vite",
    "build": "tsc && vite build",
    "build-keycloak-theme": "npm run build && keycloakify build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "serve-storybook": "yarn build-storybook && serve -s storybook-static",
    "start": "keycloakify start-keycloak",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/emails/ src/login/",
    "lint:fix": "yarn lint --fix",
    "format": "prettier \"src/emails/**/*.{ts,tsx}\" \"src/login/**/*.{ts,tsx}\" --check",
    "format:fix": "prettier \"src/emails/**/*.{ts,tsx}\" \"src/login/**/*.{ts,tsx}\" --write"
  },
  "license": "MIT",
  "keywords": [],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@keycloak/keycloak-admin-client": "26.6.1",
    "@keycloakify/keycloak-account-ui": "~260601.0.0",
    "@keycloakify/keycloak-ui-shared": "~260601.0.0",
    "@mitodl/smoot-design": "^6.10.0",
    "@mui/lab": "^7.0.1-beta",
    "@mui/material": "^7",
    "@patternfly/patternfly": "^5.4.2",
    "@patternfly/react-core": "^5.4.14",
    "@patternfly/react-icons": "^5.4.2",
    "@patternfly/react-styles": "^5.4.1",
    "@patternfly/react-table": "^5.4.16",
    "@posthog/react": "^1",
    "@remixicon/react": "^4",
    "@zootools/email-spell-checker": "^1.12.0",
    "i18next": "^25.7.3",
    "i18next-fetch-backend": "^7.0.0",
    "jsx-email": "^3",
    "keycloak-js": "^26",
    "keycloakify": "^11",
    "lodash-es": "^4.18.1",
    "oidc-spa": "~10.0.5",
    "posthog-js": "^1",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^16.5.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@eslint/js": "9.39.4",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-react": "^6",
    "@vitest/browser": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "17.7.0",
    "keycloakify-emails": "3.3.1",
    "playwright": "1.61.1",
    "prettier": "3.8.5",
    "storybook": "10.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
